[GENERAL]
display = Display_HAT_Mini

# AutoStop: Multi-sensor majority voting for reliable pause/resume
# Set to False to disable automatic pause (manual control only)
use_autostop = True

# AutoStop uses majority voting from available sensors:
# - Each sensor (speed, motion, power) gets one vote
# - Majority determines action (stopped vs moving)
# - PAUSE: Requires >50% sensors vote "stopped" for pause_delay seconds
# - RESUME: Requires >50% sensors vote "moving" for resume_delay seconds
# - Strong activity (speed > 2 km/h OR power > 10W) triggers instant resume
# - On tie votes (1-1): defaults to keep recording (fail-safe)

# Sensor voting thresholds
autostop_speed_threshold = 0.5    # km/h - below this votes "stopped"
autostop_power_threshold = 5      # watts - below this votes "stopped"

# Time delays (seconds)
autostop_pause_delay = 5.0        # majority stopped for this long
autostop_resume_delay = 1.0       # majority moving for this long

# Legacy settings (backward compatibility)
autostop_pause_threshold = 0.5
autostop_resume_threshold = 1.0
autostop_cutoff = 1
wheel_circumference = 2105
gross_ave_speed = 15
lang = EN
unit_system = metric
auto_wifi_off = False

[ANT]
STATUS = False

[DISPLAY_PARAM]
spi_clock = 2000000
use_backlight = False
auto_backlight_cutoff = 10